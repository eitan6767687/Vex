local function getKeyName(kc)
    if kc == Enum.KeyCode.Unknown then return "Unknown" end
    return kc.Name
end

local function getKeyFromName(name)
    if not name or name == "" or name == "Unknown" then return Enum.KeyCode.Unknown end
    local kc = Enum.KeyCode[name]
    if kc then return kc end
    return Enum.KeyCode.Unknown
end

