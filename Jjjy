local INF_JUMP_POWER = 55
local INF_MAX_FALL_VEL = -120
local INF_JUMP_HOLD_DELAY = 0.12

local function clearHoldJump()
    S.holdJumpPressed = false
    S.holdJumpActive = false
end

local function isHoldInfJumpMode()
    return S.infJumpMode == "hold"
end

local function getInfJumpRoot()
    local char = LP.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local function applyInfJumpBoost(boost)
    if not (S.infJumpEnabled or S.holdJumpEnabled) then return end
    local root = getInfJumpRoot()
    if root then
        root.Velocity = Vector3.new(root.Velocity.X, boost, root.Velocity.Z)
    end
end

local function stopInfJumpConnsIfIdle()
    if S.infJumpEnabled or S.holdJumpEnabled then return end
    clearHoldJump()
    if S.IJ_JumpConn then S.IJ_JumpConn:Disconnect(); S.IJ_JumpConn = nil end
    if S.IJ_InputBeganConn then S.IJ_InputBeganConn:Disconnect(); S.IJ_InputBeganConn = nil end
    if S.IJ_InputEndedConn then S.IJ_InputEndedConn:Disconnect(); S.IJ_InputEndedConn = nil end
    if S.IJ_HeartbeatConn then S.IJ_HeartbeatConn:Disconnect(); S.IJ_HeartbeatConn = nil end
end

local function ensureInfJumpConns()
    if S.IJ_JumpConn and S.IJ_InputBeganConn and S.IJ_InputEndedConn and S.IJ_HeartbeatConn then return end

    if S.IJ_JumpConn then S.IJ_JumpConn:Disconnect() end
    S.IJ_JumpConn = UIS.JumpRequest:Connect(function()
        if isHoldInfJumpMode() then return end
        if not S.infJumpEnabled then return end
        applyInfJumpBoost(INF_JUMP_POWER)
    end)

    if S.IJ_InputBeganConn then S.IJ_InputBeganConn:Disconnect() end
    S.IJ_InputBeganConn = UIS.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.Keyboard or input.KeyCode ~= Enum.KeyCode.Space then return end
        if UIS:GetFocusedTextBox() then return end
        if not S.holdJumpEnabled or not isHoldInfJumpMode() then return end
        S.holdJumpPressed = true
        applyInfJumpBoost(INF_JUMP_POWER)
        task.delay(INF_JUMP_HOLD_DELAY, function()
            if S.holdJumpPressed and S.holdJumpEnabled and isHoldInfJumpMode() then
                S.holdJumpActive = true
                applyInfJumpBoost(INF_JUMP_POWER)
            end
        end)
    end)

    if S.IJ_InputEndedConn then S.IJ_InputEndedConn:Disconnect() end
    S.IJ_InputEndedConn = UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Enum.KeyCode.Space then
            clearHoldJump()
        end
    end)

    if S.IJ_HeartbeatConn then S.IJ_HeartbeatConn:Disconnect() end
    S.IJ_HeartbeatConn = RunService.Heartbeat:Connect(function()
        if S.holdJumpActive and S.holdJumpEnabled and isHoldInfJumpMode() then
            applyInfJumpBoost(INF_JUMP_POWER)
        end
        if not (S.infJumpEnabled or S.holdJumpEnabled) then return end
        local root = getInfJumpRoot()
        if root then
            local vel = root.Velocity
            if vel.Y < INF_MAX_FALL_VEL then
                root.Velocity = Vector3.new(vel.X, INF_MAX_FALL_VEL, vel.Z)
            end
