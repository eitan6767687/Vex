    task.spawn(function()
        while card and card.Parent do
            TS_G:Create(dot, TweenInfo.new(0.45, Enum.EasingStyle.Sine), {BackgroundTransparency = 0.75}):Play()
            task.wait(0.45)
            TS_G:Create(dot, TweenInfo.new(0.45, Enum.EasingStyle.Sine), {BackgroundTransparency = 0}):Play()
            task.wait(0.45)
        end
    end)

    -- Shimmer sweep loop
    task.spawn(function()
        while card and card.Parent do
            if card.Visible and S.Steal.isStealing then
                shimmer.Position = UDim2.new(-0.25, 0, 0, 0)
                TS_G:Create(shimmer, TweenInfo.new(0.55, Enum.EasingStyle.Sine), {Position = UDim2.new(1.1, 0, 0, 0)}):Play()
                task.wait(0.65)
            else
                task.wait(0.2)
            end
        end
    end)
end

buildGui()
buildStealHUD()
createFloatingButtonPanel()

LP.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    S.setupSpeedBillboard(char)
    if S.antiRagdollEnabled then cacheAntiRagdollCharacter() end
    if S.medusaCounterEnabled then setupMedusaCounter(char) end
    if S.infJumpEnabled then startInfiniteJump() end
    if S.holdJumpEnabled then startHoldJump() end
    if S.unwalkEnabled then task.wait(1); startUnwalk() end
    S.restartMovement()
end)
if LP.Character then
    task.spawn(function()
        S.setupSpeedBillboard(LP.Character)
        if S.antiRagdollEnabled then cacheAntiRagdollCharacter() end
        if S.medusaCounterEnabled then setupMedusaCounter(LP.Character) end
    end)
end
