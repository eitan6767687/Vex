local function createFloatingButtonPanel()
    local panelGui = Instance.new("ScreenGui")
    panelGui.Name="ReviveGG_FloatingPanel"; panelGui.ResetOnSpawn=false
    panelGui.IgnoreGuiInset=true; panelGui.DisplayOrder=8
    if not pcall(function() panelGui.Parent=game:GetService("CoreGui") end) then
        panelGui.Parent=LP:WaitForChild("PlayerGui")
    end
    S.floatingPanelGui=panelGui
    local panelFrame = Instance.new("Frame", panelGui)
    panelFrame.Size=UDim2.new(0,156,0,274); panelFrame.Position=UDim2.new(1,-170,0.5,-137)
    panelFrame.BackgroundColor3=Color3.fromRGB(4,4,4); panelFrame.BackgroundTransparency=1
    panelFrame.BorderSizePixel=0; panelFrame.Active=true; panelFrame.ZIndex=20
    panelFrame.ClipsDescendants=false
    Instance.new("UICorner", panelFrame).CornerRadius=UDim.new(0,16)
    S.floatingPanelFrame=panelFrame
    applyPhoneGuiScale(panelFrame, S.phoneButtonsScale, "floatingGuiScaleObj")
    makeDraggable(panelFrame, true)

    local btnGrid = Instance.new("Frame", panelFrame)
    btnGrid.Size=UDim2.new(1,-8,1,-8); btnGrid.Position=UDim2.new(0,4,0,4)
    btnGrid.BackgroundTransparency=1; btnGrid.ZIndex=21; btnGrid.ClipsDescendants=false

    local BLACK_OFF   = Color3.fromRGB(10,8,10)
    local RED_ON      = C_RED
    local STROKE_OFF  = Color3.fromRGB(48,38,42)
    local STROKE_ON   = C_RED_GLOW
    local BUTTON_W,BUTTON_H,GAP_X,GAP_Y = 68,58,6,8

    local function getDefaultMobileButtonPos(order)
        local col=(order-1)%2; local row=math.floor((order-1)/2)
        return 2+col*(BUTTON_W+GAP_X), 2+row*(BUTTON_H+GAP_Y)
    end
    local function applyMobileButtonPos(btn,id,order)
        local defX,defY=getDefaultMobileButtonPos(order)
        local saved=S.mobileButtonPositions[id]
        local x=type(saved)=="table" and tonumber(saved.X) or defX
        local y=type(saved)=="table" and tonumber(saved.Y) or defY
        btn.Position=UDim2.fromOffset(x,y)
    end
    local function makeFloatingButtonDraggable(btn,id)
        local dragging,moved,dragInput,dragStart,startPos=false,false,nil,nil,nil
        btn.InputBegan:Connect(function(input)
            if S.lockMobileButtons then return end
            if input.UserInputType~=Enum.UserInputType.MouseButton1 and input.UserInputType~=Enum.UserInputType.Touch then return end
            dragging=true; moved=false; dragInput=input; dragStart=input.Position; startPos=btn.Position
            local conn
            conn=input.Changed:Connect(function()
                if input.UserInputState~=Enum.UserInputState.End then return end
                dragging=false; dragInput=nil
                if conn then conn:Disconnect() end
                if moved then
                    S.mobileButtonPositions[id]={X=btn.Position.X.Offset,Y=btn.Position.Y.Offset}
                    saveConfig()
                    task.delay(0.12,function() S._floatingPanelDragging=false end)
                else S._floatingPanelDragging=false end
            end)
        end)
        btn.InputChanged:Connect(function(input)
            if input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch then
                dragInput=input
            end
        end)
        UIS.InputChanged:Connect(function(input)
            if not dragging or input~=dragInput or not dragStart or not startPos then return end
            local delta=input.Position-dragStart
            if math.abs(delta.X)>3 or math.abs(delta.Y)>3 then moved=true; S._floatingPanelDragging=true end
            btn.Position=UDim2.fromOffset(startPos.X.Offset+delta.X, startPos.Y.Offset+delta.Y)
        end)
    end
    local function makePButton(id,label1,label2,order)
        local btn=Instance.new("TextButton", btnGrid)
        btn.Name=id; btn.Size=UDim2.fromOffset(BUTTON_W,BUTTON_H)
        applyMobileButtonPos(btn,id,order)
        btn.BackgroundColor3=BLACK_OFF; btn.BackgroundTransparency=0.1; btn.BorderSizePixel=0; btn.Text=""; btn.ZIndex=22
        Instance.new("UICorner", btn).CornerRadius=UDim.new(0,14)
        local stroke=Instance.new("UIStroke", btn)
        stroke.Color=STROKE_OFF; stroke.Thickness=1.2; stroke.Transparency=0.2
        -- Gradient overlay for depth
        local btnGrad=Instance.new("UIGradient", btn)
        btnGrad.Color=ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(16,12,14)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(10,8,10)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(14,10,12)),
        })
        btnGrad.Rotation = 160
        local t1=Instance.new("TextLabel", btn)
        t1.Size=UDim2.new(1,0,0.55,0); t1.Position=UDim2.new(0,0,0.06,0)
        t1.BackgroundTransparency=1; t1.Text=label1; t1.TextColor3=Color3.fromRGB(230,225,225)
        t1.Font=Enum.Font.GothamBlack; t1.TextSize=11; t1.TextXAlignment=Enum.TextXAlignment.Center; t1.ZIndex=23
        local t2=Instance.new("TextLabel", btn)
        t2.Size=UDim2.new(1,0,0.4,0); t2.Position=UDim2.new(0,0,0.55,0)
        t2.BackgroundTransparency=1; t2.Text=label2; t2.TextColor3=Color3.fromRGB(170,160,165)
        t2.Font=Enum.Font.GothamBold; t2.TextSize=8; t2.TextXAlignment=Enum.TextXAlignment.Center; t2.ZIndex=23
        if label1=="DROP" then
            t2.Visible=false; t1.Size=UDim2.new(1,0,1,0); t1.Position=UDim2.new(0,0,0,0)
            t1.TextScaled=false; t1.TextSize=12
        end
        S.mobileButtonRefs[id]=btn
        makeFloatingButtonDraggable(btn,id)
        return btn,stroke,t1,t2
    end
    local function setButtonActive(btn,stroke,l1,l2,active)
        TS_G:Create(btn,TweenInfo.new(0.18,Enum.EasingStyle.Quad),{BackgroundColor3=active and RED_ON or BLACK_OFF, BackgroundTransparency=active and 0 or 0.1}):Play()
        TS_G:Create(stroke,TweenInfo.new(0.18),{Color=active and STROKE_ON or STROKE_OFF, Transparency=active and 0 or 0.2}):Play()
        local tc=active and Color3.fromRGB(255,245,245) or Color3.fromRGB(230,225,225)
        if l1 then TS_G:Create(l1,TweenInfo.new(0.18),{TextColor3=tc}):Play() end
        if l2 then TS_G:Create(l2,TweenInfo.new(0.18),{TextColor3=active and Color3.fromRGB(255,220,220) or Color3.fromRGB(170,160,165)}):Play() end
        local grad = btn:FindFirstChildOfClass("UIGradient")
        if grad then
            if active then
                grad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(240,40,40)),
                    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(200,25,25)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(160,15,15)),
                })
            else
                grad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(16,12,14)),
                    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(10,8,10)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(14,10,12)),
                })
            end
        end
    end
    S._setPButtonActive=setButtonActive

    local btnDROP,bsDROP,l1DROP,l2DROP=makePButton("DropBrainrot","DROP","BRAINROT",1)
    local btnAL,bsAL,l1AL,l2AL=makePButton("AutoLeft","AUTO","LEFT",2)
    local btnBAT,bsBAT,l1BAT,l2BAT=makePButton("BatAimbot","BAT","AIMBOT",3)
    local btnAR,bsAR,l1AR,l2AR=makePButton("AutoRight","AUTO","RIGHT",4)
    local btnTP,bsTP,l1TP,l2TP=makePButton("TPDown","TP","DOWN",5)
    local btnCS,bsCS,l1CS,l2CS=makePButton("CarrySpeed","CARRY","SPD",6)
    local btnLAG,bsLAG,l1LAG,l2LAG=makePButton("LaggerMode","LAGGER","MODE",7)
    local btnIR,bsIR,l1IR,l2IR=makePButton("InstaReset","INSTA","RESET",8)
    S._btnAAL=btnAL; S._bsAAL=bsAL; S._l1AAL=l1AL; S._l2AAL=l2AL
    S._btnAAR=btnAR; S._bsAAR=bsAR; S._l1AAR=l1AR; S._l2AAR=l2AR
    S._btnBAT=btnBAT; S._bsBAT=bsBAT; S._l1BAT=l1BAT; S._l2BAT=l2BAT

    S._floatingButtons={
        lagger=btnLAG,strokeLagger=bsLAG,l1Lagger=l1LAG,l2Lagger=l2LAG,
        carry=btnCS,strokeCarry=bsCS,l1Carry=l1CS,l2Carry=l2CS,
        autoLeft=btnAL,strokeAutoLeft=bsAL,l1AutoLeft=l1AL,l2AutoLeft=l2AL,
        autoRight=btnAR,strokeAutoRight=bsAR,l1AutoRight=l1AR,l2AutoRight=l2AR,
        bat=btnBAT,strokeBat=bsBAT,l1Bat=l1BAT,l2Bat=l2BAT,
    }

    l1LAG.Text="LAGGER"; l2LAG.Text=""
    setButtonActive(btnLAG,bsLAG,l1LAG,l2LAG,S.laggerMode~=0)
    setButtonActive(btnCS,bsCS,l1CS,l2CS,S.speedMode)
    setButtonActive(btnAL,bsAL,l1AL,l2AL,S.autoLeftEnabled)
    setButtonActive(btnAR,bsAR,l1AR,l2AR,S.autoRightEnabled)
    setButtonActive(btnBAT,bsBAT,l1BAT,l2BAT,S.batAimbotEnabled)

    btnDROP.MouseButton1Click:Connect(function()
        if not S.lockMobileButtons then return end
        if S._floatingPanelDragging then return end
        setButtonActive(btnDROP,bsDROP,l1DROP,l2DROP,true)
        task.delay(0.5,function() setButtonActive(btnDROP,bsDROP,l1DROP,l2DROP,false) end)
        task.spawn(runDropBrainrot)
    end)
