        if newState then
            if S.autoLeftEnabled then S.autoLeftEnabled=false; stopAutoLeft(); if S.autoLeftSetVisual then S.autoLeftSetVisual(false) end; setButtonActive(btnAL,bsAL,l1AL,l2AL,false) end
            if S.batAimbotEnabled then setBatAimbot(false); setButtonActive(btnBAT,bsBAT,l1BAT,l2BAT,false) end
