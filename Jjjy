        if newState then
            if S.autoRightEnabled then S.autoRightEnabled=false; stopAutoRight(); if S.autoRightSetVisual then S.autoRightSetVisual(false) end; setButtonActive(btnAR,bsAR,l1AR,l2AR,false) end
            if S.batAimbotEnabled then setBatAimbot(false); setButtonActive(btnBAT,bsBAT,l1BAT,l2BAT,false) end
