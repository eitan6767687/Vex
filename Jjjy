local function readReviveIntroEnabledFromConfig()
    local ok, data = pcall(function()
        if isfile and readfile and isfile(CONFIG_FILE) then
            return readfile(CONFIG_FILE)
        end
        return nil
    end)
    if ok and data then
        local cfgOk, cfg = pcall(function()
            return HS:JSONDecode(data)
        end)
        if cfgOk and type(cfg) == "table" and cfg.introEnabled ~= nil then
            return cfg.introEnabled == true
        end
    end
    return true
end

local function resolveReviveIntroSoundId()
    if getcustomasset and writefile then
        local fileName = "revivegg_intro_y3k0in.mp3"
        if type(isfile) == "function" then
            local exists = false
            pcall(function()
                exists = isfile(fileName)
            end)
            if exists then
                local assetOk, asset = pcall(function()
                    return getcustomasset(fileName)
                end)
                if assetOk and asset then
                    return asset
                end
            end
        end
        local ok, data = pcall(function()
            return game:HttpGet(INTRO_MUSIC_URL)
        end)
        if (not ok or not data or #data == 0) then
            local req = request or http_request or (syn and syn.request)
            if req then
                ok, data = pcall(function()
                    local response = req({
                        Url = INTRO_MUSIC_URL,
                        Method = "GET",
                    })
                    return response and (response.Body or response.body)
                end)
            end
        end
        if ok and data and #data > 0 then
            local wrote = pcall(function()
                writefile(fileName, data)
            end)
            if wrote then
                local assetOk, asset = pcall(function()
                    return getcustomasset(fileName)
                end)
                if assetOk and asset then
                    return asset
                end
            end
        end
    end

    return INTRO_MUSIC_URL
end

local function playReviveIntroMusic(startAt, stopAt, volume)
    task.spawn(function()
        local sound = Instance.new("Sound")
        sound.Name = "ReviveIntroMusic"
        sound.SoundId = resolveReviveIntroSoundId()
        sound.Volume = volume or INTRO_MUSIC_VOLUME
        sound.Looped = false
        sound.Parent = game:GetService("SoundService")

        local startPos = startAt or INTRO_MUSIC_START
        local stopPos = stopAt or INTRO_MUSIC_END
        local playFor = math.max(stopPos - startPos, 0.25)

        pcall(function()
            sound.TimePosition = startPos
            sound:Play()
        end)
        task.delay(0.1, function()
            pcall(function()
                sound.TimePosition = startPos
            end)
        end)

        task.wait(playFor)
        pcall(function()
            local fade = TS_G:Create(sound, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Volume = 0,
            })
            fade:Play()
            fade.Completed:Wait()
            sound:Stop()
            sound:Destroy()
        end)
    end)
end

