local _espFrameCount = 0
local function updateESP()
    if not S.espEnabled then clearESP(); return end
    _espFrameCount = _espFrameCount + 1
    if _espFrameCount % 3 ~= 0 then return end

    local myChar = LP.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    -- Tracer origin: my own character's screen position
    local myScreenPos, myOnScreen = camera:WorldToViewportPoint(myRoot.Position)
    local myVec = Vector2.new(myScreenPos.X, myScreenPos.Y)

    local currentPlayers = Players:GetPlayers()
    local plrSet = {}
    for _, p in ipairs(currentPlayers) do plrSet[p] = true end

    for plr in pairs(S.espHighlightCache) do
        if not plrSet[plr] then removeESPForPlayer(plr) end
    end
    for plr in pairs(S.espTracerCache) do
        if not plrSet[plr] then removeESPForPlayer(plr) end
    end

    for _, plr in ipairs(currentPlayers) do
        if plr == LP then continue end
        local char = plr.Character
        if not char then removeESPForPlayer(plr); continue end

        local tRoot = char:FindFirstChild("HumanoidRootPart")
        local tHead = char:FindFirstChild("Head")
        local tHum  = char:FindFirstChildOfClass("Humanoid")
        local alive = tRoot and tHead and tHum and tHum.Health > 0

        if alive then
            -- ג”€ג”€ 1. Highlight (chams) ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€
            local hl = S.espHighlightCache[plr]
            if not hl or not hl.Parent or hl.Parent ~= char then
                if hl then pcall(function() hl:Destroy() end) end
                hl = Instance.new("Highlight")
                hl.Name                = "ReviveESP"
                hl.FillColor           = Color3.fromRGB(200, 0, 0)
                hl.FillTransparency    = 0.72
                hl.OutlineColor        = Color3.fromRGB(255, 70, 70)
                hl.OutlineTransparency = 0.05
                hl.Adornee             = char
                hl.Parent              = char
                S.espHighlightCache[plr] = hl
            end

            -- ג”€ג”€ 2. Tiny name tag ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€
            local bb = S.espBillboardCache[plr]
            if not bb or not bb.Parent or bb.Adornee ~= tHead then
                if bb then pcall(function() bb:Destroy() end) end
                local newBB, lbl = makeESPBillboard(tHead)
                lbl.Text = plr.DisplayName
                S.espBillboardCache[plr] = newBB
            end

            -- ג”€ג”€ 3. Tracer (3-layer glow) from me to them ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€ג”€
            local lines = S.espTracerCache[plr]
            if not lines then
                lines = makeESPTracers()
                S.espTracerCache[plr] = lines or {}
            end
            if lines and #lines > 0 then
                local footPos = tRoot.Position - Vector3.new(0, 2.5, 0)
                local pos, onScreen = camera:WorldToViewportPoint(footPos)
                if onScreen and pos.Z > 0 and myOnScreen then
                    local tVec = Vector2.new(pos.X, pos.Y)
                    for _, ln in ipairs(lines) do
                        ln.From    = myVec
                        ln.To      = tVec
                        ln.Visible = true
                    end
                else
                    for _, ln in ipairs(lines) do ln.Visible = false end
                end
            end
        else
            -- Dead / respawning ג€” clean up
            if S.espHighlightCache[plr] then
                pcall(function() S.espHighlightCache[plr]:Destroy() end)
                S.espHighlightCache[plr] = nil
            end
            if S.espBillboardCache[plr] then
                pcall(function() S.espBillboardCache[plr]:Destroy() end)
                S.espBillboardCache[plr] = nil
            end
            if S.espTracerCache[plr] then
                for _, ln in ipairs(S.espTracerCache[plr]) do
                    pcall(function() ln.Visible = false end)
                end
            end
        end
    end
end

