function startBatAimbot()
    if S.batAimbotConn then S.batAimbotConn:Disconnect() end
    queueAutoBatStart()
    S.batAimbotConn = RunService.Heartbeat:Connect(function()
        if not S.batAimbotEnabled then return end
        local char = LP.Character; if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root or not hum then return end

        if not S.autoBatEquippedThisRun then
            S.autoBatEquippedThisRun = true
            if not char:FindFirstChildOfClass("Tool") then
                local bp = LP:FindFirstChildOfClass("Backpack") or LP:FindFirstChild("Backpack")
                local bpBat = bp and bp:FindFirstChild("Bat")
                if bpBat then
                    pcall(function() hum:EquipTool(bpBat) end)
                end
            end
        end

        local target = getAutoBatTarget()
        if target then
            local targetVel = target.Velocity
            local aimTargetPos = target.Position
                + (targetVel * math.clamp(targetVel.Magnitude / 130, 0.05, 0.15))
                + Vector3.new(0, AUTO_BAT_V_OFF, 0)
            hum.AutoRotate = false
            local look = aimTargetPos - root.Position
            local flatLook = Vector3.new(look.X, 0, look.Z)
            if look.Magnitude > 0.01 then
                local yawDelta = 0
                if flatLook.Magnitude > 0.01 then
                    local targetYaw = math.deg(math.atan2(-flatLook.X, -flatLook.Z))
                    yawDelta = (targetYaw - root.Orientation.Y + 180) % 360 - 180
                end
                local targetPitch = -math.deg(math.atan2(look.Y, math.max(flatLook.Magnitude, 0.001)))
                local pitchDelta = (targetPitch - root.Orientation.X + 180) % 360 - 180
                local yawRate = math.clamp(math.rad(yawDelta) * AUTO_BAT_TURN_SPEED, -AUTO_BAT_MAX_TURN_RATE, AUTO_BAT_MAX_TURN_RATE)
                local pitchRate = math.clamp(math.rad(pitchDelta) * AUTO_BAT_TURN_SPEED, -AUTO_BAT_MAX_TURN_RATE, AUTO_BAT_MAX_TURN_RATE)
                local yawRad = math.rad(root.Orientation.Y)
                local rightAxis = Vector3.new(math.cos(yawRad), 0, -math.sin(yawRad))
                root.RotVelocity = Vector3.new(0, yawRate, 0) + (rightAxis * pitchRate)
            else
                root.RotVelocity = Vector3.zero
            end
            local dir = look.Magnitude > 0.01 and look.Unit or Vector3.zero
            local closeTargetPos = target.Position + Vector3.new(0, AUTO_BAT_HEIGHT, 0)
            local standPos = closeTargetPos - (dir * AUTO_BAT_DIST)
            local moveDir = standPos - root.Position
            local hDir = Vector3.new(moveDir.X, 0, moveDir.Z)
            local hVel = hDir.Magnitude > 0.1 and hDir.Unit * AUTO_BAT_SPEED or Vector3.zero
            local vVel = math.abs(moveDir.Y) > 0.1 and Vector3.new(0, math.sign(moveDir.Y) * AUTO_BAT_VERT_SPEED, 0)
                or Vector3.new(0, -2, 0)
            root.Velocity = hVel + vVel
            if hDir.Magnitude > 0.5 then
                hum:Move(hDir.Unit, false)
            end
        else
            hum.AutoRotate = true
            root.RotVelocity = Vector3.zero
        end

        if S.autoSwingEnabled then
            local bat = char:FindFirstChild("Bat")
            if bat and bat:IsA("Tool") then
                bat:Activate()
            end
        end
    end)
end

