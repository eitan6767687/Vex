    TS:Create(p2, TweenInfo.new(0.08), {BackgroundColor3=SB_ACCENT_DK}):Play()
    task.delay(0.2, function() TS:Create(p2, TweenInfo.new(0.1), {BackgroundColor3=SB_CARD2}):Play() end)
end)

powerInput.FocusLost:Connect(function()
    local n = tonumber(powerInput.Text)
    if n then
        if Config.Mode == "PC" then
            Config.PCPower = math.clamp(n, 10000, 150000); powerInput.Text = tostring(Config.PCPower)
        else
            Config.MobilePower = math.clamp(n, 10000, 100000); powerInput.Text = tostring(Config.MobilePower)
        end
    else
        powerInput.Text = tostring(getCurrentPower())
    end
    SaveConfig()
    if running then restartSpamLoop() end
end)

kbEditBtn.MouseButton1Click:Connect(function()
    if listeningKB then return end
    listeningKB = true
    kbKeyLbl.Text = "[...]"
    kbKeyLbl.TextColor3 = Color3.fromRGB(200,200,100)
    kbEditBtn.BackgroundColor3 = Color3.fromRGB(80,80,0)
end)

UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if listeningKB then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            Config.Keybind = input.KeyCode.Name
            kbKeyLbl.Text = "[" .. Config.Keybind .. "]"
            kbKeyLbl.TextColor3 = SB_ACCENT
            kbEditBtn.BackgroundColor3 = SB_ACCENT_DK
            listeningKB = false
            SaveConfig()
        end
    elseif input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode.Name == Config.Keybind then
        Toggle()
    end
end)

updateModeBtns(Config.Mode)
powerInput.Text = tostring(getCurrentPower())

main.Visible = true
gui.Enabled = true

print("[Vex SpeedBypass] UI fully loaded · " .. Config.Keybind .. " to toggle")
