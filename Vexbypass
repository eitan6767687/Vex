local function getCurrentPower() return Config.Mode=="PC" and Config.PCPower or Config.MobilePower end

local function restartSpamLoop()
    if not running then return end
    if spamThread then pcall(function() task.cancel(spamThread) end) end
    bomb = buildBomb(getCurrentPower())
    local rrs = game:FindFirstChild("RobloxReplicatedStorage")
    local remote = rrs and rrs:FindFirstChild("SetPlayerBlockList")
    if not remote then
        warn("[Vex SpeedBypass] SetPlayerBlockList not found - this game may not support the bypass")
        return
    end
    spamThread = task.spawn(function()
        while running do
            if bomb then
                pcall(function() remote:FireServer(bomb) end)
            end
            task.wait(Config.SpamDelay)
        end
    end)
end

local function Toggle()
    running = not running
    if running then
        pcall(function() NetworkClient:SetOutgoingKBPSLimit(math.huge) end)
        restartSpamLoop()
        setActiveVisual(true)
    else
        if spamThread then pcall(function() task.cancel(spamThread) end) end
        bomb = nil; spamThread = nil
        pcall(function() NetworkClient:SetOutgoingKBPSLimit(0) end)
        setActiveVisual(false)
    end
end

local function SwitchMode(newMode)
    if running then Toggle() end
    Config.Mode = newMode
    updateModeBtns(newMode)
    powerInput.Text = tostring(getCurrentPower())
    SaveConfig()
end

local function setPreset(d)
    Config.SpamDelay = d
    verLbl.Text = "  " .. getVerName(d)
    SaveConfig()
    if running then restartSpamLoop() end
end

